{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NClientT",
  "version": "0.1.0",
  "identifier": "com.nclientt.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NClientT",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "android": {
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MANAGE_EXTERNAL_STORAGE"
      ]
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://* data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; connect-src 'self' ipc: https://*",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Entertainment",
    "shortDescription": "NClientT comic client",
    "longDescription": "NClientT is a cross-platform desktop client for browsing and downloading galleries, ported from NClientV3.",
    "copyright": "Licensed under the Apache License, Version 2.0",
    "publisher": "NClientT"
  }
}
